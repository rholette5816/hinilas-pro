{
  "headers": [
    {
      "source": "/og-image.png",
      "headers": [
        {
          "key": "Content-Type",
          "value": "image/png"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/dropoff-emails",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/dropoff-emails-angles",
      "schedule": "30 1 * * *"
    },
    {
      "path": "/api/cron/dropoff-emails-signup",
      "schedule": "0 2 * * *"
    }
  ]
}
